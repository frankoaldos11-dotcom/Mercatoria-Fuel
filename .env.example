# ──────────────────────────────────────────────
# MERCATORIA FUEL — Variables de entorno
# Copia este archivo como .env y completa los valores.
# NUNCA subas .env al repositorio.
# ──────────────────────────────────────────────

# Clave secreta de Flask (obligatoria)
# Genera una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-segura-generada-aleatoriamente

# Base de datos
# Si se define DATABASE_URL la app usa PostgreSQL; si no, usa SQLite local (fuel.db).
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_base_datos

# Migraciones PostgreSQL
# Establecer en "true" para saltar la ejecución automática de migraciones al arrancar.
SKIP_MIGRATIONS=false
